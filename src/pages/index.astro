---
import BaseHead from '@/components/BaseHead.astro';
import { FOLDER_CONFIG } from '@/const';
import { getCollection } from 'astro:content';

// IDのパス部分を数値と文字列の配列に変換（例: "linear/1/2" -> ["linear", 1, 2]）
const parsePathParts = (id: string) => {
	return id.split('/').map(part => {
		const num = parseInt(part);
		return isNaN(num) ? part : num;
	});
};

// パスの各部分を順番に比較してソート順を決定
const compareByPath = (a: string, b: string) => {
	const partsA = parsePathParts(a);
	const partsB = parsePathParts(b);
	
	for (let i = 0; i < Math.min(partsA.length, partsB.length); i++) {
		if (partsA[i] < partsB[i]) return -1;
		if (partsA[i] > partsB[i]) return 1;
	}
	return partsA.length - partsB.length;
};

const allPosts = await getCollection('blog');

// フォルダごとに記事をグループ化
const postsMap = new Map<string, typeof allPosts>();
for (const post of allPosts) {
	const folderName = post.id.split('/')[0];
	if (!postsMap.has(folderName)) {
		postsMap.set(folderName, []);
	}
	postsMap.get(folderName)!.push(post);
}

// 各フォルダ内で記事をパス順にソート
for (const posts of postsMap.values()) {
	posts.sort((a, b) => compareByPath(a.id, b.id));
}

// 設定されたフォルダを順序に従って配列に並べる
const folders = Object.keys(FOLDER_CONFIG)
	.sort((a, b) => FOLDER_CONFIG[a].order - FOLDER_CONFIG[b].order)
	.filter(folderName => postsMap.has(folderName))
	.map(folderName => ({
		name: folderName,
		title: FOLDER_CONFIG[folderName].title,
		posts: postsMap.get(folderName)!
	}));

const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title="数学のページ" />
		<style>
			main {
				max-width: 800px;
				margin: 0 auto;
				padding: 2em 1em;
			}
			.folder-section {
				margin-bottom: 3em;
			}
			.folder-title {
				font-size: 1.5em;
				margin-bottom: 1em;
				padding-bottom: 0.5em;
				border-bottom: 2px solid #333;
			}
			ul {
				list-style: none;
				padding: 0;
			}
			li {
				margin-bottom: 1em;
			}
			a {
				text-decoration: none;
				color: inherit;
			}
			a:hover {
				text-decoration: underline;
			}
		</style>
	</head>
	<body>
		<main>
			{folders.map((folder) => (
				<div class="folder-section">
					<h2 class="folder-title">{folder.title}</h2>
					<ul>
						{folder.posts.map((post) => (
							<li>
								<a href={`${baseUrl}${post.id}/`}>
									<h3>{post.data.title}</h3>
								</a>
							</li>
						))}
					</ul>
				</div>
			))}
		</main>
	</body>
</html>
